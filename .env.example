# Required
OPENROUTER_API_KEY=sk-or-v1-...

# Data directory
# - Bare metal: set to the absolute path where the archive lives
# - Docker: ignored — docker-compose.yml overrides this to /data
SIDECAR_DATA_DIR=/srv/sidecar-data

# Optional: API config
OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
OCR_ENGINE=mistral-ocr
CLASSIFY_MODEL=google/gemma-4-31b-it

# Optional: server
HOST=0.0.0.0
PORT=8080

# Optional: logging
LOG_LEVEL=INFO

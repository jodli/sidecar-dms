{$SIDECAR_DOMAIN:localhost} {
	root * {$SIDECAR_SRC_DIR:./src}

	handle /health {
		respond "OK" 200
	}

	handle_path /archive/* {
		root * {$SIDECAR_DATA_DIR:./sidecar-data}/archive
		file_server
	}

	handle_path /pagefind/* {
		root * {$SIDECAR_DATA_DIR:./sidecar-data}/pagefind
		file_server
	}

	@manifest path /manifest-*.json
	handle @manifest {
		root * {$SIDECAR_DATA_DIR:./sidecar-data}
		file_server
	}

	file_server
	try_files {path} /index.html
	encode gzip
}

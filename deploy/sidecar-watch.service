[Unit]
Description=Sidecar DMS - Watch intake folder for new PDFs
After=network.target

[Service]
Type=simple
User=jodli
WorkingDirectory=/mnt/quickstuff/git/sidecar-dms
EnvironmentFile=/mnt/quickstuff/git/sidecar-dms/.env
ExecStart=/mnt/quickstuff/git/sidecar-dms/.venv/bin/python tools/watch_intake.py
Restart=on-failure
RestartSec=10

# Graceful shutdown: SIGTERM → finish current batch
KillSignal=SIGTERM
TimeoutStopSec=120

[Install]
WantedBy=multi-user.target
